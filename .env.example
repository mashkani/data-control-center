# Data Control Center — optional environment template
#
# Copy to `.env` only if you want a local file; the backend does not load this path
# automatically. Export variables in your shell or use your process manager.
# Full reference: backend/README.md#configuration

# --- Local-only security ---
# DCC_LOCAL_ONLY=true
# DCC_ALLOW_NON_LOCAL_HOST=false
# DCC_REQUIRE_LOCAL_API_TOKEN=true
# DCC_LOCAL_API_TOKEN=

# --- Workspace ---
# DCC_WORKSPACE_DB_PATH=.dcc_workspace.duckdb

# --- Uploads (browser upload is the normal path) ---
# DCC_UPLOAD_DIR=.dcc_uploads
# DCC_UPLOAD_MAX_BYTES_PER_FILE=2147483648
# DCC_UPLOAD_MAX_BATCH_BYTES=2147483648

# --- Path registration (advanced; off by default) ---
# DCC_ENABLE_PATH_REGISTRATION=false
# DCC_REGISTRATION_ALLOWED_ROOTS=
# DCC_EXPOSE_ABSOLUTE_SOURCE_PATHS=false

# --- Query / samples ---
# DCC_QUERY_MAX_ROWS=10000
# DCC_QUERY_TIMEOUT_SECONDS=8

# --- Local LLM (Ask tab; optional) ---
# DCC_LLM_BASE_URL=http://127.0.0.1:11434
# DCC_LLM_MODEL=qwen3:4b
# DCC_AGENT_SUMMARIZE_WITH_LLM=true
# DCC_AGENT_MAX_ROWS=500

# --- Single-server / dev UI ---
# DCC_UI_DIST_PATH=
# DCC_DEV_UI_ORIGIN=http://localhost:5173
